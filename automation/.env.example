# SynerGy Apex LATAM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Supabase (required) ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=eyJhbGci...your-anon-key...

# ── Banxico SIE (optional — enables live México macro data) ───────────────
# Register free at: https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_TOKEN=

# ── INEGI (optional — enables live México demographic data) ───────────────
# Register free at: https://www.inegi.org.mx/app/api/indicadores/
INEGI_TOKEN=

# ── Email notifications (optional) ───────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=recipient@email.com

# ── Notes ──────────────────────────────────────────────────────────────────
# Sources that work WITHOUT any API key (no setup needed):
#   - BCRP Peru:  https://estadisticas.bcrp.gob.pe/estadisticas/series/api/
#   - BCB Brazil: https://api.bcb.gov.br/dados/serie/bcdata.sgs.{id}/dados/
#   - IBGE:       https://servicodados.ibge.gov.br/api/v3/
#   - open.er-api: https://open.er-api.com/v6/latest/USD
#
# Sources that need a free token:
#   - Banxico SIE (BANXICO_TOKEN): México rates + inflation + PIB growth
#   - INEGI API   (INEGI_TOKEN):   México unemployment + population
